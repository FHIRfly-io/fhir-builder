{
  "name": "@fhirfly-io/fhir-builder",
  "version": "0.1.0",
  "description": "Fluent TypeScript builder for FHIR R4 resources. Free, offline, open source.",
  "author": "FHIRfly.io LLC <admin@fhirfly.io>",
  "license": "Apache-2.0",
  "type": "module",
  "homepage": "https://fhirfly.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FHIRfly-io/fhir-builder.git"
  },
  "bugs": {
    "url": "https://github.com/FHIRfly-io/fhir-builder/issues"
  },
  "keywords": [
    "fhir",
    "hl7",
    "healthcare",
    "interoperability",
    "r4",
    "builder",
    "typescript",
    "fhir-resources",
    "patient",
    "observation",
    "bundle",
    "us-core",
    "clinical",
    "medical",
    "fhirfly"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/fhir": "^0.0.41",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
